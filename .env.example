# Copy to ".env.local" (never commit .env.local).
# Dashboard → Project Settings → API
# Prefer anon (legacy JWT). Publishable (sb_publishable_…) also works as fallback.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional if you do not use ANON_KEY:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: n8n Webhook (POST JSON from server after save, includes Supabase id). Prefer server-only:
# N8N_INQUIRY_WEBHOOK_URL=
# Or keep using the public name (also read on the server):
NEXT_PUBLIC_N8N_INQUIRY_WEBHOOK_URL=

# Optional: service role — lets the server return row id without the submit_inquiry RPC. Never expose in client code.
SUPABASE_SERVICE_ROLE_KEY=
